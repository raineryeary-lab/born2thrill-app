# Public app URL used for auth redirects and canonical links.
NEXT_PUBLIC_SITE_URL=

# Railway PostgreSQL.
# Set this in Railway from the PostgreSQL service reference, not in Git.
DATABASE_URL=

# Supabase compatibility variables.
# Keep these only while Auth/Storage still run through Supabase.
# Remove them after Auth and uploads have been migrated away from Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
